# ─────────────────────────────────────────────
# EISR Portal — Environment Variables Template
# Copy this file to .env.local for development
# Set these as real secrets in production
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── JWT Authentication ────────────────────────
# IMPORTANT: Use a long, random secret in production!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_64_CHARS_MINIMUM

# ── MySQL Database ────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=eisr_user
MYSQL_PASSWORD=password2root
MYSQL_DATABASE=eisr_db5

# ── Email (Forgot Password) ───────────────────
# Leave blank to skip email — reset link will be shown on-screen (dev mode)
# For Gmail: use an App Password (not your normal password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
